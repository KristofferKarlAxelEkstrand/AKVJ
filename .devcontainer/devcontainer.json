{
	"name": "AKVJ - Node.js",
	"image": "mcr.microsoft.com/devcontainers/javascript-node:4-22-bookworm",
	"remoteUser": "node",

	// Two Vite apps + Admin API + sharp clip pipeline
	"hostRequirements": {
		"cpus": 4,
		"memory": "8gb"
	},

	// vj-server Vite (5173), preview (4173), admin Vite (5174), admin API (8787)
	"forwardPorts": [5173, 4173, 5174, 8787],

	"portsAttributes": {
		"5173": {
			"label": "vj-server Vite",
			"onAutoForward": "openBrowser"
		},
		"4173": {
			"label": "vj-server Preview",
			"onAutoForward": "notify"
		},
		"5174": {
			"label": "admin Vite",
			"onAutoForward": "notify"
		},
		"8787": {
			"label": "admin API",
			"onAutoForward": "silent"
		}
	},

	// Auto-install dependencies after container creation
	"postCreateCommand": "npm install",

	// Ensure clips are validated on start (uses sharp for PNG optimization)
	"postStartCommand": "npm run clips:validate 2>/dev/null || true",

	// Fallback env var for file watching on macOS/Windows Docker hosts where inotify doesn't propagate.
	// The vite.config.js already detects container env vars (REMOTE_CONTAINERS, CODESPACES, GITPOD)
	// and enables polling automatically. This is a secondary safety net for chokidar-based watchers.
	"containerEnv": {
		"REMOTE_CONTAINERS": "true"
	},

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode", "stylelint.vscode-stylelint", "eamodio.gitlens", "jdinhlife.gruvbox", "vitest.explorer", "antfu.vite", "GitHub.vscode-github-actions"],
			"settings": {
				"workbench.colorTheme": "Gruvbox Dark Medium"
			}
		}
	}
}

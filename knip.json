{
	"ignore": [".agents/**"],
	"entry": ["e2e/**/*.spec.js", "playwright.config.js"],
	"workspaces": {
		"akvj": {
			"entry": ["test/**/*.test.js"],
			"project": ["src/**/*.js", "test/**/*.js", "scripts/**/*.js"],
			"ignore": ["src/tools/clip-preview/ClipPreview.js"]
		},
		"mainframe": {
			"entry": ["test/**/*.test.js"],
			"project": ["src/**/*.js", "server/**/*.js", "scripts/**/*.js", "test/**/*.js"]
		},
		"midi-mcp": {
			"entry": ["test/**/*.test.js"],
			"project": ["lib/**/*.js", "test/**/*.js"],
			"ignore": ["lib/transformers/mtcTransformer.js"]
		}
	},
	"ignoreBinaries": ["fuser", "pkill"]
}

{
	"name": "akvj",
	"version": "0.0.0",
	"description": "AKVJ monorepo — live VJ engine (akvj) and set management tooling (mainframe).",
	"author": {
		"email": "hej@kristofferekstrand.se",
		"name": "Kristoffer Ekstrand",
		"url": "https://kristofferekstrand.se"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.7.0",
		"knip": "^6.27.0",
		"prettier": "3.9.5",
		"stylelint": "^17.14.0",
		"stylelint-config-recommended": "^18.0.0",
		"stylelint-order": "^8.1.1"
	},
	"engines": {
		"node": ">=20"
	},
	"license": "MIT",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/KristofferKarlAxelEkstrand/AKVJ"
	},
	"scripts": {
		"build": "npm run build -w akvj",
		"build:all": "npm run clips && npm run build -w akvj && npm run build -w mainframe",
		"build:full": "npm run clips && npm run build -w akvj",
		"check:eol": "node monorepo-scripts/check-line-endings.js",
		"check:package-json": "node monorepo-scripts/sort-package-json.js --check",
		"check:utf8": "node monorepo-scripts/check-utf8.js",
		"clips": "node mainframe/scripts/clips",
		"clips:clean": "node mainframe/scripts/clips --clean",
		"clips:new": "node mainframe/scripts/clips/new.js",
		"clips:spritesheet": "node mainframe/scripts/clips/spritesheet.js",
		"clips:validate": "node mainframe/scripts/clips --validate-only",
		"clips:watch": "node mainframe/scripts/clips --watch",
		"akvj": "npm run dev -w akvj",
		"mainframe": "npm run dev -w mainframe",
		"fix:eol": "node monorepo-scripts/check-line-endings.js --fix",
		"fix:utf8": "node monorepo-scripts/check-utf8.js --fix",
		"format:check": "prettier --check . && npm run check:package-json",
		"format:prettier": "prettier --write .",
		"format:sort-package-json": "node monorepo-scripts/sort-package-json.js",
		"format:stylelint": "stylelint \"**/*.css\" --fix",
		"lint": "eslint .",
		"lint:css": "stylelint \"**/*.css\"",
		"lint:fix": "eslint . --fix",
		"knip": "knip",
		"preview": "npm run preview -w akvj",
		"sort-package-json": "node monorepo-scripts/sort-package-json.js",
		"test": "npm run test -w akvj",
		"test:all": "npm run test -w akvj && npm run test -w mainframe",
		"test:smoke": "node mainframe/test/smoke/startup.test.js",
		"test:smoke:mainframe": "node mainframe/test/smoke/mainframe-startup.test.js",
		"test:ci": "npm run test:ci -w akvj",
		"test:e2e": "npx playwright test",
		"test:e2e:all": "npm run test:smoke && npx playwright test",
		"test:e2e:install": "npx playwright install chromium",
		"test:visual": "npm run test:visual -w akvj && npm run test:visual -w mainframe",
		"test:visual:update": "npm run test:visual:update -w akvj && npm run test:visual:update -w mainframe"
	},
	"type": "module",
	"workspaces": [
		"akvj",
		"mainframe"
	]
}

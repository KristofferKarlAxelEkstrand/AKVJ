  "dls_system_messages": [
    {
      "name": "Turn DLS Level 1 On",
      "message": "F0 7E < device ID > 0A 01 F7",
      "bytes": [
        {
          "byte": "F0 7E",
          "description": "Universal Non-Real Time SysEx header"
        },
        {
          "byte": "< device ID >",
          "description": "ID of target device (suggest using 7F: Broadcast)"
        },
        {
          "byte": "0A",
          "description": "sub-ID #1 = DLS Level 1 message"
        },
        {
          "byte": "01",
          "description": "sub-ID #2 = DLS Level 1 On"
        },
        {
          "byte": "F7",
          "description": "EOX"
        }
      ]
    },
    {
      "name": "Turn DLS Level 1 Off",

  "metadata": {
    "title": "Scalable Polyphony MIDI (SP-MIDI) Specification and Device Profiles",
    "doc_id": "RP-034/RP-035",
    "protocol": "midi1",
    "version": "1.0b",
    "date": "2004-11-15"
  },
  "terminology": [
    {
      "term": "Note",
      "description": "Note is used to refer a note that begins with a Note On MIDI message and ends with a Note Off MIDI"
    },
    {
      "term": "Note Generator",
      "description": "Note Generator refers to rendering hardware or software needed to play one note, e.g. to respond to"
    },
    {
      "term": "Note Stealing",
      "description": "Note Stealing refers to terminating a Note and reallocating its sound generator(s) before the"
    },
    {
      "term": "Channel Priority",
      "description": "Channel Priority defines the priority order of MIDI Channels for Channel Masking and dynamic"
    },
    {
      "term": "Polyphony Level",
      "description": "Polyphony Level defines the maximum number of Notes that a Scalable Polyphony synthesizer can"
    },
    {
      "term": "Channel Masking",
      "description": "Channel Masking means muting (i.e., masking, or ignoring) a number of lowest-priority MIDI"
    },
    {
      "term": "Maximum Instantaneous Polyphony (MIP)",
      "description": "Maximum Instantaneous Polyphony (MIP) specifies the total number of Notes required for proper"
    },
    {
      "term": "Sound Module",
      "description": "Sound Module refers to a sound-generating device that receives MIDI data in real time, typically"
    }
  ],
  "mip_message_syntax": [
    "[UNIVERSAL REALTIME SYSTEM EXCLUSIVE]",
    "F0 7F <device ID> 0B 01 {cc vv} {cc vv} {cc vv} ... {cc vv} {cc vv} F7",
    "F0 7F Universal Real Time SysEx header",
    "<device ID> ID of target device (7F = all devices)",
    "0B sub-ID#1 = Scalable Polyphony MIDI",
    "01 sub-ID#2 = MIP Message",
    "cc MIDI Channel number (0x00 = ch1, 0x01 = ch2 etc.)",
    "vv Maximum Instantaneous Polyphony (MIP) value of the",
    "F7 EOX"
  ],

{
  "metadata": {
    "title": "Sample Dump Size, Rate and Name Extensions",
    "doc_id": "CA-019",
    "version": "1.0.0",
    "source": "ca19.md"
  },
  "sub_commands": [
    {
      "name": "EXTENDED DUMP HEADER",
      "sub_command": "05",
      "byte_fields": [
        {
          "variable": "ee",
          "description": "Sample Format (# of significant Bits from 8 - 28)"
        },
        {
          "variable": "ff ff ff ff",
          "description": "Sample rate integer portion in Hertz (LSB first)"
        },
        {
          "variable": "gg gg gg gg",
          "description": "Sample rate fractional portion in Hertz (LSB first)"
        },
        {
          "variable": "hh hh hh hh hh",
          "description": "Sample length in words (0 - 32 GB) (LSB first)"
        },
        {
          "variable": "ii ii ii ii ii",
          "description": "Sustain Loop start point word number (LSB first)"
        },
        {
          "variable": "jj jj jj jj jj",
          "description": "Sustain Loop end point word number (LSB first)"
        },
        {
          "variable": "kk",
          "description": "Loop type"
        },
        {
          "variable": "ll",
          "description": "Number of channels"
        }
      ]
    },
    {
      "name": "EXTENDED LOOP POINT Transmission",
      "sub_command": "06",
      "byte_fields": [
        {
          "variable": "bb bb",
          "description": "Loop Number (LSB First: 7F 7F delete all loops)"
        },
        {
          "variable": "cc",
          "description": "Loop Type (same as in Extended Dump Header)"
        },
        {
          "variable": "dd dd dd dd dd",
          "description": "Loop Start Address"
        },
        {
          "variable": "ee ee ee ee ee",
          "description": "Loop End Address"
        }
      ]
    },
    {
      "name": "EXTENDED LOOP POINT Request",
      "sub_command": "07",
      "byte_fields": [
        {
          "variable": "bb bb",
          "description": "Loop Number (LSB First: 7F 7F request all loops)"
        }
      ]
    },
    {
      "name": "SAMPLE NAME TRANSMISSION",
      "sub_command": "03",
      "byte_fields": [
        {
          "variable": "tt",
          "description": "Sample Name Language Tag Length (default: 00)"
        },
        {
          "variable": "nn",
          "description": "Sample Name Length (up to 127 characters)"
        }
      ]
    },
    {
      "name": "SAMPLE NAME REQUEST",
      "sub_command": "04",
      "byte_fields": []
    }
  ],
  "loop_types": [
    {
      "value": "00",
      "description": "Forward playback with unidirectional loop. Sample plays from sample start to loop"
    },
    {
      "value": "01",
      "description": "Forward playback with bi-directional loop. Sample plays from sample start to loop"
    },
    {
      "value": "02",
      "description": "Forward playback with unidirectional loop and release. Sample plays from sample"
    },
    {
      "value": "03",
      "description": "Forward playback with bi-directional loop and release. Sample plays from sample"
    },
    {
      "value": "40",
      "description": "Backward playback with unidirectional loop. Sample plays from sample end to"
    },
    {
      "value": "41",
      "description": "Backward playback with bi-directional loop. Sample plays from sample end to"
    },
    {
      "value": "42",
      "description": "Backward playback with unidirectional loop and release. Sample plays"
    },
    {
      "value": "43",
      "description": "Backward playback with bi-directional loop and release. Sample plays backwards"
    },
    {
      "value": "7E",
      "description": "Backward one-shot playback, no looping."
    },
    {
      "value": "7F",
      "description": "Forward one-shot playback, no looping."
    }
  ],
  "examples": [
    {
      "message": "F0 7E 01 05 04 00 01 F7",
      "description": "Requests name of sample #1"
    },
    {
      "message": "F0 7E 01 05 03 00 01 00 0B 54 65 73 74 20 53 61 6D 70 6C 65 F7",
      "description": "SAMPLE NAME Transmit (from Sampler) - “Test Sample”:"
    },
    {
      "message": "F0 7E 01 05 03 00 01 00 0E 52 65 6E 61 6D 65 64 20 53 61 6D 70 6C 65 F7",
      "description": "SAMPLE NAME Transmit (from Computer) - “Renamed Sample”"
    }
  ]
}
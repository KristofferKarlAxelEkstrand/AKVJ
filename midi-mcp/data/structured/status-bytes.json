  "categories": [
    {
      "name": "channel_voice",
      "description": "Channel Voice Messages",
      "messages": [
        {
          "status": "0x8n",
          "message": "Note Off",
          "total_bytes": 3,
          "data_byte_1": "Note number (0–127)",
          "data_byte_2": "Release velocity"
        },
        {
          "status": "0x9n",
          "message": "Note On",
          "total_bytes": 3,
          "data_byte_1": "Note number (0–127)",
          "data_byte_2": "Velocity (0 = Note Off)"
        },
        {
          "status": "0xAn",
          "message": "Polyphonic Key Pressure",
          "total_bytes": 3,
          "data_byte_1": "Note number",
          "data_byte_2": "Pressure"
        },
        {
          "status": "0xBn",
          "message": "Control Change",
          "total_bytes": 3,
          "data_byte_1": "Controller (0–119)",
          "data_byte_2": "Value"
        },
        {
          "status": "0xBn",
          "message": "Channel Mode (CC 120–127)",
          "total_bytes": 3,
          "data_byte_1": "Controller (120–127)",
          "data_byte_2": "Value"
        },
        {
          "status": "0xCn",
          "message": "Program Change",
          "total_bytes": 2,
          "data_byte_1": "Program number",
          "data_byte_2": "—"
        },
        {
          "status": "0xDn",
          "message": "Channel Pressure",
          "total_bytes": 2,
          "data_byte_1": "Pressure",
          "data_byte_2": "—"
        },
        {
          "status": "0xEn",
          "message": "Pitch Bend",
          "total_bytes": 3,
          "data_byte_1": "LSB",
          "data_byte_2": "MSB (value = LSB + MSB×128, center 8192)"
        }
      ]
    },
    {
      "name": "system_common",
      "description": "System Common Messages",
      "messages": [
        {
          "status": "0xF0",
          "message": "System Exclusive start",
          "total_bytes": "variable",
          "data": "Manufacturer ID, then data bytes until 0xF7"
        },
        {
          "status": "0xF1",
          "message": "MTC Quarter Frame",
          "total_bytes": 2,
          "data": "Time code nibble"
        },
        {
          "status": "0xF2",
          "message": "Song Position Pointer",
          "total_bytes": 3,
          "data": "LSB, MSB (in MIDI beats = 6 clocks)"
        },
        {
          "status": "0xF3",
          "message": "Song Select",
          "total_bytes": 2,
          "data": "Song number"
        },
        {
          "status": "0xF4",
          "message": "(undefined/reserved)",
          "total_bytes": null,
          "data": "Invalid"
        },
        {
          "status": "0xF5",
          "message": "(undefined/reserved)",
          "total_bytes": null,
          "data": "Invalid"
        },
        {
          "status": "0xF6",
          "message": "Tune Request",
          "total_bytes": 1,
          "data": "—"
        },
        {
          "status": "0xF7",
          "message": "End of Exclusive (EOX)",
          "total_bytes": 1,
          "data": "Terminates SysEx"
        }
      ]
    },
    {
      "name": "system_real_time",
      "description": "System Real-Time Messages",
      "messages": [
        {
          "status": "0xF8",
          "message": "Timing Clock",
          "notes": "24 pulses per quarter note (fixed)"
        },
        {
          "status": "0xF9",
          "message": "(undefined/reserved)",
          "notes": "Invalid"
        },
        {
          "status": "0xFA",
          "message": "Start",
          "notes": "Play from the beginning; clocks follow"
        },
        {
          "status": "0xFB",
          "message": "Continue",
          "notes": "Resume from current position"
        },
        {
          "status": "0xFC",
          "message": "Stop",
          "notes": "Halt playback"
        },
        {
          "status": "0xFD",
          "message": "(undefined/reserved)",
          "notes": "Invalid"
        },
        {
          "status": "0xFE",
          "message": "Active Sensing",
          "notes": "Optional ≤300ms heartbeat"
        },
        {
          "status": "0xFF",
          "message": "System Reset",
          "notes": "Reset device to power-up state"
        }
      ]
    }
  ],
  "parsing_rules": [
    "**Running status**: after a channel-message status byte, subsequent messages of the same status may omit it. Cancelled by any System Common message; System Real-Time bytes do NOT cancel or affect running status. The Web MIDI API never uses running status in `MIDIOutput.send()` and delivers complete messages to `onmidimessage`.",
    "System Real-Time bytes (0xF8–0xFF) may appear between the bytes of another message; process them immediately and continue the interrupted message.",
    "Data bytes without a preceding status byte (and no running status) must be ignored."
  ]
}
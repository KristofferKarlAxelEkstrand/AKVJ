  "message_format": {
    "template": "F0 7F <device ID> 0A 01 0n kk [nn vv] .. F7",
    "fields": [
      {
        "code": "F0",
        "description": "7F Universal Real Time SysEx header"
      },
      {
        "code": "<device ID>",
        "description": "ID of target device (7F = all devices)"
      },
      {
        "code": "0A",
        "description": "sub-ID#1 = “Key-Based Instrument Control”"
      },
      {
        "code": "01",
        "description": "sub-ID#2 = 01 Basic Message"
      },
      {
        "code": "0n",
        "description": "MIDI Channel Number"
      },
      {
        "code": "kk",
        "description": "Key number"
      },
      {
        "code": "[nn,vv]",
        "description": "Controller Number and Value"
      }
    ]
  },

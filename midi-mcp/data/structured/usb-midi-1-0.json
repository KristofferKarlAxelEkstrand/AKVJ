{
  "metadata": {
    "title": "USB Device Class Definition for MIDI Devices",
    "doc_id": "USB-MIDI-1.0",
    "protocol": "midi1",
    "version": "1.0",
    "date": "1999-11-01"
  },
  "cin_classifications": [
    {
      "cin": "0x0",
      "midi_x_size": "1, 2 or 3",
      "description": "Miscellaneous function codes. Reserved for future extensions."
    },
    {
      "cin": "0x1",
      "midi_x_size": "1, 2 or 3",
      "description": "Cable events. Reserved for future expansion."
    },
    {
      "cin": "0x2",
      "midi_x_size": "2",
      "description": "Two-byte System Common messages like MTC, SongSelect, etc."
    },
    {
      "cin": "0x3",
      "midi_x_size": "3",
      "description": "Three-byte System Common messages like SPP, etc."
    },
    {
      "cin": "0x4",
      "midi_x_size": "3",
      "description": "SysEx starts or continues"
    },
    {
      "cin": "0x5",
      "midi_x_size": "1",
      "description": "Single-byte System Common Message"
    },
    {
      "cin": "0x6",
      "midi_x_size": "2",
      "description": "SysEx ends with following two bytes."
    },
    {
      "cin": "0x7",
      "midi_x_size": "3",
      "description": "SysEx ends with following three bytes."
    },
    {
      "cin": "0x8",
      "midi_x_size": "3",
      "description": "Note-off"
    },
    {
      "cin": "0x9",
      "midi_x_size": "3",
      "description": "Note-on"
    },
    {
      "cin": "0xA",
      "midi_x_size": "3",
      "description": "Poly-KeyPress"
    },
    {
      "cin": "0xB",
      "midi_x_size": "3",
      "description": "Control Change"
    },
    {
      "cin": "0xC",
      "midi_x_size": "2",
      "description": "Program Change"
    },
    {
      "cin": "0xD",
      "midi_x_size": "2",
      "description": "Channel Pressure"
    },
    {
      "cin": "0xE",
      "midi_x_size": "3",
      "description": "PitchBend Change"
    },
    {
      "cin": "0xF",
      "midi_x_size": "1",
      "description": "Single Byte"
    }
  ],
  "parsed_event_examples": [
    {
      "description": "Note-on message on virtual cable 1 (CN=0x1; CIN=0x9)",
      "midi_event": "9n kk vv",
      "event_packet": "19 9n kk vv"
    },
    {
      "description": "Control change message on cable 10 (CN=0xA; CIN=0xB)",
      "midi_event": "Bn pp vv",
      "event_packet": "AB Bn pp vv"
    },
    {
      "description": "Real-time message F8 on cable 3 (CN=0x3; CIN=0xF)",
      "midi_event": "F8 xx xx",
      "event_packet": "3F F8 xx xx"
    },
    {
      "description": "SysEx message on cable p (CN=0xp). Start of SysEx: CIN=0x4. End of SysEx: CIN=0x5",
      "midi_event": "F0 00 01 F7",
      "event_packet": "p4 F0 00 01 + p5 F7 00 00"
    },
    {
      "description": "SysEx message on cable p (CN=0xp). Start of SysEx: CIN=0x4. End of SysEx: CIN=0x6",
      "midi_event": "F0 00 01 02 F7",
      "event_packet": "p4 F0 00 01 + p6 02 F7 00"
    },
    {
      "description": "SysEx message on cable p (CN=0xp). Start of SysEx: CIN=0x4. End of SysEx: CIN=0x7",
      "midi_event": "F0 00 01 02 03 F7",
      "event_packet": "p4 F0 00 01 + p7 02 03 F7"
    },
    {
      "description": "Special case: two-byte SysEx on cable p (CN=0xp; CIN=0x6)",
      "midi_event": "F0 F7",
      "event_packet": "p6 F0 F7 00"
    },
    {
      "description": "Special case: three-byte SysEx on cable p (CN=0xp; CIN=0x7)",
      "midi_event": "F0 mm F7",
      "event_packet": "p7 F0 mm F7"
    }
  ],
  "element_capabilities": [

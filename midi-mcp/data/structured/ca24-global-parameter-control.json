{
  "metadata": {
    "title": "Global Parameter Control",
    "doc_id": "CA-024",
    "version": "1.0.0",
    "source": "ca24-global-parameter-control-sysex-message.md"
  },
  "message_format": {
    "template": "F0 7F <device ID> 04 05 sw pw vw [[sh sl] ... ] [pp vv] ... F7",
    "byte_fields": [
      {
        "code": "sw",
        "description": "Slot Path Length. The number of 2-byte entries in the slot path. Can be zero if no slot path is needed (top-level parameters)."
      },
      {
        "code": "pw",
        "description": "Parameter ID Width. The number of bytes used for the <pp> field."
      },
      {
        "code": "vw",
        "description": "Value Width. The number of bytes used for the <vv> field. (optional) Variable length slot path (Length set by <sw> field):"
      },
      {
        "code": "sh",
        "description": "Slot Number MSB. A value of 1 here in a slot path of length 1 is reserved for GM2 (see comments)."
      },
      {
        "code": "sl",
        "description": "Slot Number LSB. Variable length parameter-value pair list (terminated by EOX):"
      },
      {
        "code": "pp",
        "description": "Parameter ID, MSB first. Width set by <pw> field."
      },
      {
        "code": "vv",
        "description": "Parameter Value, LSB first. Width set by <vw> field."
      }
    ]
  },
  "example": {
    "fields": [
      {
        "hex": "<device ID>",
        "description": "ID of Target Device (7F = all devices)"
      },
      {
        "hex": "02",
        "description": "Slot Path Length = 2"
      },
      {
        "hex": "01",
        "description": "Parameter ID Width = 1"
      },
      {
        "hex": "02",
        "description": "Value Width = 2"
      },
      {
        "hex": "01",
        "description": "Slot Path 1 MSB = 1 (Main mix channels use MSB = 1)"
      },
      {
        "hex": "47",
        "description": "Slot Path 1 LSB = 47H (Main mix channel 71)"
      },
      {
        "hex": "02",
        "description": "Slot Path 2 MSB = 2 (Insert effects use MSB = 2)"
      },
      {
        "hex": "03",
        "description": "Slot Path 2 LSB = 3 (Insert effect 3)"
      },
      {
        "hex": "04",
        "description": "Parameter to be controlled = 4"
      },
      {
        "hex": "VL",
        "description": "Value LSB for the parameter"
      },
      {
        "hex": "VH",
        "description": "Value MSB for the parameter"
      }
    ]
  },

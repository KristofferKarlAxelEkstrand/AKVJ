        "param_id": 1,
        "name": "Mod Rate",
        "formula": "mr = val * 0.122",
        "description": "Mr is the modulation frequency in Hz."
      },
      {
        "param_id": 2,
        "name": "Mod Depth",
        "formula": "md = (val + 1) / 3.2",
        "description": "Md is the peak-to-peak swing of the modulation in ms."
      },
      {
        "param_id": 3,
        "name": "Feedback",
        "formula": "fb = val * 0.763",
        "description": "Fb is the amount of feedback from Chorus output in percent."
      },
      {
        "param_id": 4,
        "name": "Send to Reverb",
        "formula": "ctr = val * 0.787",
        "description": "Ctr is the send level from Chorus to Reverb in percent."

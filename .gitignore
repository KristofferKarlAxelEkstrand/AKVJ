# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*

# Agent workflow state
.agents/workflows/developer-team/scripts/.await-state.json
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency directories
node_modules/

# Build outputs
dist/
dist-ssr/
/akvj/dist/
/mainframe/dist/

# Leftover pre-monorepo paths (never reintroduce)
/src/
/scripts/
/test/

# Local environment files
*.local
.env
.env.*
!.env.example

# Editor directories and files
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite cache
.vite/

# Temporary files
tmp/
temp/
tmp-*.js

# Clip pipeline outputs
.cache/
/akvj/src/public/clips/

# MIDI spec raw sources (copyrighted binaries, local-only; extracted text lives in midi-mcp/data/)
/.midi-raw-data/
/midi-mcp/.cache/

# System files
Thumbs.db

# Visual test diffs (generated on failure)
test/visual/__diffs__/
akvj/test/visual/__diffs__/
**/test/visual/__diffs__/

# Vitest browser-mode attachments
.vitest-attachments/

# Agent skills (machine-local private skills)
.agents/skills-local/*
!.agents/skills-local/.gitkeep

# Claude Code runtime artifacts (local to each machine — .claude/skills/ symlinks ARE committed)
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json
.claude/routines/.state/
.claude/worktrees/
.claude/checkpoints/
.claude/mailbox/
.claude/agent-registry.json
.claude/agent-memory-local
.claude/first-run
.claude/assistant-daemon-state.json
.claude/settings.local.json
.midi-raw-data/
